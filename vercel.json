{
  "version": 2,
  "functions": {
    "backend/server.py": {
      "runtime": "vercel-python@0.1.0"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/server.py"
    },
    {
      "source": "/admin",
      "destination": "/frontend/index.html"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/frontend/index.html"
    }
  ]
}
